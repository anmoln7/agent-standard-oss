# Force LF line endings for shell scripts regardless of platform checkout
# settings. A CRLF checkout breaks bash on the shebang line even when the
# git index stores LF — see CI's "CRLF regression check".
*.sh text eol=lf
install.sh text eol=lf
bin/* text eol=lf
tests/*.sh text eol=lf
templates/**/*.sh text eol=lf
