#!/bin/bash
# adopt — a friendly five-minute onboarding for the agent standard.
# Built for people who don't live in the terminal: it explains every step in
# plain English, asks before changing anything, and never deletes or overwrites
# your work.
#
#   adopt              # interactive walkthrough — run it inside your project folder
#   adopt --check      # just show the scorecard, change nothing (exit 1 if gaps remain)
#   adopt --check --json  # scorecard as machine-readable JSON, change nothing
#   adopt --yes        # accept every suggestion without asking (for scripts/CI)
set -uo pipefail

SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
TPL="$SELF_DIR/../templates"

mode=interactive
json=0
for a in "$@"; do
  case "$a" in
    --check) mode=check ;;
    --yes)   mode=yes ;;
    --json)  json=1 ;;
    -h|--help) sed -n '2,10p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "usage: adopt [--check [--json]|--yes]"; exit 1 ;;
  esac
done
if [ "$json" = 1 ] && [ "$mode" != "check" ]; then
  echo "usage: --json is only valid with --check"; exit 1
fi

# pretty output; degrades to plain text when piped
if [ -t 1 ]; then BOLD=$'\033[1m'; RST=$'\033[0m'; GRN=$'\033[32m'; DIM=$'\033[2m'
else BOLD=""; RST=""; GRN=""; DIM=""; fi

ask(){  # ask "plain-English question" → 0 = yes
  if [ "$mode" = "yes" ]; then echo "   → yes (auto)"; return 0; fi
  printf '   %s [Y/n] ' "$1"
  read -r a || a=n
  case "$a" in n*|N*) return 1 ;; *) return 0 ;; esac
}

changed=()          # files this run touched, for the summary + optional commit
note(){ changed+=("$1"); }

step_n=0            # wizard progress: counts over the gaps left, not a fixed 1..6
gaps(){ local g=0 c; for c in c_git c_agents c_claude c_fixlog c_ignore c_sync; do "$c" || g=$((g+1)); done; echo "$g"; }
# total is recounted live: one fix can close two checks (the skeleton includes
# the sync section), and the plan shrinks with it so the last step is N of N
step(){ step_n=$((step_n+1)); echo ""; echo "   ${BOLD}Step ${step_n} of $((step_n + $(gaps) - 1)) — $1${RST}"; }

# work from the project root if we're inside a git repo
if git rev-parse --show-toplevel >/dev/null 2>&1; then
  cd "$(git rev-parse --show-toplevel)" || exit 1
fi
repo_name="$(basename "$PWD")"

# ── the six checks ───────────────────────────────────────────────────────────
# Each check has a STABLE ID (STD-01 … STD-06). IDs are a public contract: an ID
# never changes meaning, and removing or repurposing one is a breaking change for
# anyone gating CI on the --json output. See STANDARD.md §1.
c_git()    { git rev-parse --git-dir >/dev/null 2>&1; }               # STD-01
c_agents() { [ -f AGENTS.md ]; }                                      # STD-02
c_claude() { [ -L CLAUDE.md ] || { [ -f CLAUDE.md ] && head -1 CLAUDE.md | grep -q '^@AGENTS.md'; }; }  # STD-03
c_fixlog() { [ -d docs/solutions ]; }                                 # STD-04
c_ignore() { [ -f .gitignore ] && grep -qE '^\.env' .gitignore; }     # STD-05
c_sync()   { [ -f AGENTS.md ] && grep -q '^## Keep in sync' AGENTS.md; }  # STD-06

# Maturity level gates on the SHAPE of the harness, not the raw point total:
# a repo can't be "almost perfect" while leaking secrets. Secret hygiene (STD-05)
# is a floor for the top level, not one point among six.
#   L0 unharnessed  — no AGENTS.md
#   L1 documented   — AGENTS.md present
#   L2 structured   — L1 + include (STD-03) + fix log (STD-04) + sync block (STD-06)
#   L3 safe         — L2 + git (STD-01) + secret hygiene (STD-05)
level(){
  c_agents || { echo 0; return; }
  if c_git && c_claude && c_fixlog && c_ignore && c_sync; then echo 3; return; fi
  if c_claude && c_fixlog && c_sync; then echo 2; return; fi
  echo 1
}
# One-line reason the NEXT level is blocked (empty at the top level).
level_gap(){
  case "$(level)" in
    0) echo "add an AGENTS.md → reach L1" ;;
    1) c_claude || { echo "point CLAUDE.md at AGENTS.md → toward L2"; return; }
       c_fixlog || { echo "add docs/solutions/ → toward L2"; return; }
       c_sync   && echo "toward L2" || echo "add a 'Keep in sync' block → toward L2" ;;
    2) c_git    || { echo "save the repo with git → toward L3"; return; }
       c_ignore && echo "toward L3" || echo "gitignore your .env (secret hygiene) → reach L3" ;;
    *) echo "" ;;
  esac
}
level_name(){ case "$1" in 0) echo "unharnessed";; 1) echo "documented";; 2) echo "structured";; *) echo "safe";; esac; }

score=0
scorecard_json(){
  local n=0 first=1 lvl; lvl="$(level)"
  printf '{"repo":"%s","level":%d,"level_name":"%s","checks":[' \
    "$repo_name" "$lvl" "$(level_name "$lvl")"
  jrow(){ # jrow <fn> <id> <key>
    [ "$first" = 1 ] || printf ','
    first=0
    if "$1"; then printf '{"id":"%s","key":"%s","pass":true}' "$2" "$3"; n=$((n+1))
    else printf '{"id":"%s","key":"%s","pass":false}' "$2" "$3"; fi
  }
  jrow c_git    STD-01 git
  jrow c_agents STD-02 agents_md
  jrow c_claude STD-03 claude_md_include
  jrow c_fixlog STD-04 fix_log
  jrow c_ignore STD-05 gitignore_env
  jrow c_sync   STD-06 keep_in_sync
  printf '],"score":%d,"total":6}\n' "$n"
  score=$n
}

scorecard(){
  if [ "$json" = 1 ]; then scorecard_json; return; fi
  local n=0 miss=""
  echo ""
  echo "   ${BOLD}${repo_name} — checkup${RST}"
  echo "   ──────────────────────────────────────────────────────────"
  row(){ if "$1"; then echo "   ✅ $2"; n=$((n+1)); else echo "   ⬜ $2"; [ -n "$miss" ] || miss="$2"; fi; }
  row c_git    "Saved with git (every change can be undone)"
  row c_agents "AGENTS.md — the one welcome note every AI assistant reads"
  row c_claude "CLAUDE.md points at AGENTS.md (no duplicate copy to drift)"
  row c_fixlog "docs/solutions/ — a diary of solved problems"
  row c_ignore ".gitignore keeps secret files (.env) out of history"
  row c_sync   "A 'Keep in sync' list so related files never disagree"
  local bar="" i=0
  while [ "$i" -lt 6 ]; do
    if [ "$i" -lt "$n" ]; then bar="${bar}${GRN}■${RST}"; else bar="${bar}${DIM}□${RST}"; fi
    i=$((i+1))
  done
  local lvl; lvl="$(level)"
  echo "   ──────────────────────────────────────────────────────────"
  echo "   level: ${BOLD}L${lvl} · $(level_name "$lvl")${RST}   score: $n/6  $bar"
  # Level (shape) drives the headline, not the raw count — a repo that leaks
  # secrets is never "almost perfect", however many other checks it passes.
  case "$lvl" in
    3) echo "   🏆 ${BOLD}fully harnessed — guides, a fix log, and secret hygiene all in place${RST}" ;;
    2) echo "   🛡️ structured guidance is in — one floor left: secret hygiene + git for L3" ;;
    1) echo "   📖 documented — add the include, fix log, and sync block for L2" ;;
    0) echo "   🌱 untouched soil — an AGENTS.md is the first step (L1)" ;;
  esac
  if [ "$mode" = "check" ]; then
    local gap; gap="$(level_gap)"
    if [ -n "$gap" ]; then
      echo ""
      echo "   next → $gap"
      echo "   (run ${BOLD}adopt${RST} to close the gaps — it asks first, deletes nothing)"
    fi
  fi
  score=$n
}

skeleton(){  # write a starter AGENTS.md with plain-English TODOs
  cat > AGENTS.md <<EOF
# $repo_name — Agent Guide

TODO: one sentence saying what this project is.

## Architecture

TODO: where the important things live — 3 to 5 bullet points.

## Commands

TODO: how to run / build / test this project.

## Conventions

TODO: house rules an assistant should follow (naming, style, "don't touch X").

## Gotchas

The traps. (Past-incident write-ups live in [docs/solutions/](docs/solutions/).)

## Before shipping

TODO: what must pass before a change counts as done (tests? a manual check?).

## Keep in sync

- TODO: list file pairs that must agree, e.g. "add a setting → document it in the README".
EOF
}

sync_block(){
  cat >> AGENTS.md <<'EOF'

## Keep in sync

- TODO: list file pairs that must agree, e.g. "add a setting → document it in the README".
EOF
}

# ── welcome + first look ─────────────────────────────────────────────────────
if [ "$mode" != "check" ]; then
  echo ""
  echo "   👋 ${BOLD}Hi! Let's introduce your project to its AI helpers.${RST}"
  echo ""
  echo "   This wizard sets up ${repo_name} so AI coding assistants (Claude Code,"
  echo "   Codex, Cursor, Gemini) always know how it works — and never re-learn"
  echo "   the same lesson twice. It asks before every change. Nothing is deleted."
fi

scorecard
if [ "$mode" = "check" ]; then
  # Gate on reaching the top maturity level (L3 = all six checks incl. the
  # secret-hygiene floor). Equivalent to 6/6 today, but the ladder is the API.
  [ "$(level)" -eq 3 ] && exit 0 || exit 1
fi
if [ "$score" -eq 6 ]; then
  echo ""
  echo "   🎉 Nothing to do — ${repo_name} already follows the standard!"
  exit 0
fi

# ── step 1: git ──────────────────────────────────────────────────────────────
if ! c_git; then
  step "give your project an undo button"
  echo "   git quietly keeps a history of every change, so nothing is ever lost."
  if ask "Turn on git for this folder?"; then
    git init -q && echo "   ✓ done — this folder now keeps its own history."
  fi
fi

# ── step 2: AGENTS.md ────────────────────────────────────────────────────────
if ! c_agents; then
  step "the welcome note (AGENTS.md)"
  echo "   One file that tells every AI assistant what this project is, how to"
  echo "   run it, and the house rules."
  if [ -f CLAUDE.md ] && [ ! -L CLAUDE.md ] && ! head -1 CLAUDE.md | grep -q '^@AGENTS.md'; then
    echo "   You already have notes in CLAUDE.md — perfect, they just move to the"
    echo "   standard filename so EVERY assistant reads them (not only Claude)."
    if ask "Rename CLAUDE.md to AGENTS.md (contents unchanged)?"; then
      git mv CLAUDE.md AGENTS.md 2>/dev/null || mv CLAUDE.md AGENTS.md
      note AGENTS.md
      echo "   ✓ moved. Nothing was lost — same words, better filename."
    fi
  else
    if ask "Create a starter AGENTS.md for ${repo_name}? (fill the TODOs later)"; then
      skeleton
      note AGENTS.md
      echo "   ✓ created. Plain sentences are perfect — no jargon needed."
    fi
  fi
fi

# ── step 3: CLAUDE.md include ────────────────────────────────────────────────
if c_agents && ! c_claude; then
  step "point Claude at the same note"
  if [ -f CLAUDE.md ]; then
    echo "   ⚠ You have BOTH CLAUDE.md and AGENTS.md with their own content."
    echo "     Merging them needs a human eye (see STANDARD.md §1) — skipping this"
    echo "     step so nothing gets lost."
  else
    echo "   Claude Code reads CLAUDE.md, so we make it a one-line pointer to"
    echo "   AGENTS.md. One source of truth; nothing to keep in two places."
    if ask "Create the one-line CLAUDE.md pointer?"; then
      printf '@AGENTS.md\n' > CLAUDE.md
      note CLAUDE.md
      echo "   ✓ done."
    fi
  fi
fi

# ── step 4: the fix log ──────────────────────────────────────────────────────
if ! c_fixlog; then
  step "a diary of solved problems (docs/solutions/)"
  echo "   Every time a tricky bug gets fixed, it gets one small page here — so"
  echo "   no human or AI ever has to solve it twice."
  if ask "Create docs/solutions/ (with one worked example)?"; then
    mkdir -p docs/solutions
    if ls "$TPL"/docs/solutions/EXAMPLE-*.md >/dev/null 2>&1; then
      cp "$TPL"/docs/solutions/EXAMPLE-*.md docs/solutions/ 2>/dev/null
    fi
    note docs/solutions
    echo "   ✓ created."
  fi
fi

# ── step 5: keep secrets out ─────────────────────────────────────────────────
if ! c_ignore; then
  step "keep passwords out of the history"
  echo "   Secret files (like .env) should never be saved into git — once they're"
  echo "   in the history, they're very hard to remove."
  if ask "Add the secret-file rules to .gitignore?"; then
    printf '\n# secrets live here — never commit them (added by agent-standard adopt)\n.env\n.env.*\n!.env.example\n' >> .gitignore
    note .gitignore
    echo "   ✓ added."
  fi
fi

# ── step 6: keep-in-sync list ────────────────────────────────────────────────
if c_agents && ! c_sync; then
  step "the 'Keep in sync' list"
  echo "   A short list in AGENTS.md naming files that must agree (so when one"
  echo "   changes, the other gets updated too — that's how notes stay honest)."
  if ask "Add a starter 'Keep in sync' section to AGENTS.md?"; then
    sync_block
    note AGENTS.md
    echo "   ✓ added — replace the TODO with your real file pairs."
  fi
fi

# ── bonus: pre-commit secret guard ───────────────────────────────────────────
if c_git && [ -f "$TPL/git/hooks/pre-commit" ]; then
  hook="$(git rev-parse --git-dir)/hooks/pre-commit"
  if [ ! -e "$hook" ]; then
    echo ""
    echo "   ${BOLD}Bonus — a guard that blocks accidental password commits${RST}"
    echo "   (works best with gitleaks installed: brew install gitleaks)"
    if ask "Install the pre-commit secret guard for this project?"; then
      cp "$TPL/git/hooks/pre-commit" "$hook" && chmod +x "$hook"
      echo "   ✓ installed — commits containing likely secrets will be stopped."
    fi
  fi
fi

# ── the after picture ────────────────────────────────────────────────────────
scorecard
echo ""
if [ "$score" -eq 6 ]; then
  echo "   🎉 ${BOLD}All set! ${repo_name} now speaks fluent AI-assistant.${RST}"
  echo ""
  echo "   Next (5 minutes, no jargon): open AGENTS.md and replace the TODO"
  echo "   lines with plain sentences. That's genuinely all there is."
  echo ""
  echo "   Want to show it off? Grab the 'adopted' badge and add your repo to"
  echo "   https://github.com/anmoln7/agent-standard-oss/blob/main/ADOPTERS.md"
else
  echo "   Good progress — run ${BOLD}adopt${RST} again anytime to finish the rest."
fi

# offer to save exactly what we touched (never a blanket git add -A)
if c_git && [ "${#changed[@]}" -gt 0 ]; then
  echo ""
  if ask "Save (commit) these changes with git?"; then
    git add -- ${changed[@]+"${changed[@]}"} 2>/dev/null
    if git commit -qm "adopt the agent standard" 2>/dev/null; then
      echo "   ✓ saved. (Undo anytime with: git revert HEAD)"
    else
      echo "   ⚠ couldn't save automatically (git may want your name/email first)."
      echo "     Your files are all still there — this only affects the history."
    fi
  fi
fi
echo ""
