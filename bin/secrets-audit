#!/bin/bash
# secrets-audit — full-history secret scan of a git repo (not just staged).
# Use to vet a repo you suspect, or before making one public.
#
#   secrets-audit              # scan the current repo
#   secrets-audit /path/to/repo
#   secrets-audit --all        # scan every repo under $AGENT_STD_ROOTS (default ~/Documents/GitHub)
set -uo pipefail

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "secrets-audit: gitleaks not installed (brew install gitleaks)" >&2
  exit 2
fi

scan_one() {
  local repo="$1"
  [ -d "$repo/.git" ] || { echo "  (skip, not a git repo) $repo"; return; }
  local out
  out="$(gitleaks git --no-banner --redact "$repo" 2>&1)"
  if [ $? -ne 0 ]; then
    echo "🛑 SECRETS in ${repo/$HOME/~}:"
    echo "$out" | grep -iE 'finding|secret|rule|file|commit|line' | sed 's/^/     /' | head -40
  else
    echo "✓ clean: ${repo/$HOME/~}"
  fi
}

if [ "${1:-}" = "--all" ]; then
  ROOT="${AGENT_STD_ROOTS%%:*}"; ROOT="${ROOT:-$HOME/Documents/GitHub}"
  for d in "$ROOT"/*/; do
    [ "$(basename "$d")" = "_archive" ] && continue
    scan_one "${d%/}"
  done
else
  scan_one "${1:-$PWD}"
fi
